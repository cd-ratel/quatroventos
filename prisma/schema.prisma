generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Appointment {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  date      DateTime
  timeSlot  String
  slotKey   String?  @unique
  eventType String
  guests    Int?
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
  @@map("appointments")
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  category     String   @default("gallery")
  caption      String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([category])
  @@map("media")
}

model Settings {
  id            String @id @default("main")
  businessHours Json   @default("{}")
  phone         String @default("")
  email         String @default("")
  address       String @default("")
  whatsapp      String @default("")
  instagram     String @default("")
  facebook      String @default("")
  venueTitle    String @default("Quatro Ventos")
  venueSubtitle String @default("Espaço para Eventos")
  aboutText     String @default("")
  homeContent   Json   @default("{}")
  spacesContent Json   @default("{}")
  galleryContent Json  @default("{}")
  bookingContent Json  @default("{}")
  contactContent Json  @default("{}")
  footerContent Json   @default("{}")

  @@map("settings")
}
